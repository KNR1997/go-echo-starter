# Server Configuration
HOST=0.0.0.0
PORT=7788
EXPOSE_PORT=7788

# Database Configuration (External PostgreSQL)
DB_HOST=your-postgres-host.com
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_SSLMODE=require  # Use 'require' for production, 'disable' for local
DB_DRIVER=postgres
DB_TIMEZONE=UTC

# Auth Configuration
ACCESS_SECRET=your-strong-access-secret-key-here
REFRESH_SECRET=your-strong-refresh-secret-key-here
ACCESS_SECRET_DURATION=2h
REFRESH_SECRET_DURATION=168h

# OAuth Configuration
OPEN_ID_CLIENT_ID=your-google-oauth-client-id

# Logging
LOG_LEVEL=INFO
LOG_APPLICATION=go-echo-starter
LOG_ADD_SOURCE=false
LOG_FILE=/var/log/app.log  # Optional